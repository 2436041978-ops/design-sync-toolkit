{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignIntentBaseline",
  "description": "设计意图基线格式规范",
  "type": "object",
  "required": [
    "intent_id",
    "description",
    "layer",
    "priority",
    "ownership",
    "status",
    "created_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "description": "意图唯一标识符，如 R001",
      "pattern": "^[A-Z][0-9]{3}$"
    },
    "description": {
      "type": "string",
      "description": "设计意图的详细描述",
      "minLength": 1,
      "maxLength": 1000
    },
    "layer": {
      "type": "string",
      "description": "所属架构层级",
      "enum": ["input", "validation", "output"]
    },
    "priority": {
      "type": "string",
      "description": "优先级",
      "enum": ["P0", "P1", "P2"]
    },
    "ownership": {
      "type": "object",
      "description": "责任人信息",
      "required": ["design", "product"],
      "properties": {
        "design": {
          "type": "string",
          "description": "设计负责人"
        },
        "product": {
          "type": "string",
          "description": "产品负责人"
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "description": "当前状态",
      "enum": ["draft", "reviewing", "approved", "rejected"]
    },
    "created_at": {
      "type": "string",
      "description": "创建时间 (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "description": "更新时间 (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "version": {
      "type": "string",
      "description": "版本号",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "dependencies": {
      "type": "array",
      "description": "依赖的其他意图 ID",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][0-9]{3}$"
      },
      "default": []
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "验收标准列表",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "description": "标签列表",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
