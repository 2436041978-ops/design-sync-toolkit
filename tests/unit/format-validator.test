import { FormatValidator, ValidationResult } from '../../core/format-validator';

describe('FormatValidator', () => {
  let validator: FormatValidator;

  beforeEach(() => {
    validator = new FormatValidator();
  });

  /**
   * 辅助函数：生成有效的完整 YAML 内容
   */
  function getValidYaml(overrides: Record<string, any> = {}): string {
    const base = {
      intent_id: 'R001',
      description: '用户登录流程优化',
      layer: 'input',
      priority: 'P0',
      ownership: {
        design: 'Alice',
        product: 'Bob'
      },
      status: 'draft',
      created_at: '2024-01-01',
      updated_at: '2024-01-01',
      version: '1.0.0',
      dependencies: [],
      acceptance_criteria: ['3步完成登录'],
      tags: ['login', 'ux']
    };
    const merged = { ...base, ...overrides };

    // 手动构建 YAML 字符串
    const lines: string[] = [];
    lines.push(`intent_id: "${merged.intent_id}"`);
    lines.push(`description: "${merged.description}"`);
    lines.push(`layer: "${merged.layer}"`);
    lines.push(`priority: "${merged.priority}"`);
    lines.push('ownership:');
    lines.push(`  design: "${merged.ownership.design}"`);
    lines.push(`  product: "${merged.ownership.product}"`);
    lines.push(`status: "${merged.status}"`);
    lines.push(`created_at: "${merged.created_at}"`);
    lines.push(`updated_at: "${merged.updated_at}"`);
    lines.push(`version: "${merged.version}"`);
    lines.push(`dependencies: [${(merged.dependencies as string[]).map((d: string) => `"${d}"`).join(', ')}]`);
    if ((merged.acceptance_criteria as string[]).length === 0) {
      lines.push('acceptance_criteria: []');
    } else {
      lines.push('acceptance_criteria:');
      (merged.acceptance_criteria as string[]).forEach((c: string) => lines.push(`  - "${c}"`));
    }
    lines.push(`tags: [${(merged.tags as string[]).map((t: string) => `"${t}"`).join(', ')}]`);

    return lines.join('\n');
  }

  describe('有效 YAML 校验', () => {
    test('应通过完整有效的 YAML 校验', () => {
      const yaml = getValidYaml();
      const result = validator.validate(yaml);
      expect(result.valid).toBe(true);
      expect(result.errors).toBeUndefined();
    });

    test('应通过带有可选字段的最小有效 YAML 校验', () => {
      const yaml = getValidYaml({
        dependencies: ['R002'],
        tags: ['feature']
      });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(true);
    });

    test('所有 layer 枚举值应被接受', () => {
      const layers = ['input', 'validation', 'output'];
      layers.forEach((layer) => {
        const yaml = getValidYaml({ layer });
        const result = validator.validate(yaml);
        expect(result.valid).toBe(true);
      });
    });

    test('所有 priority 枚举值应被接受', () => {
      const priorities = ['P0', 'P1', 'P2'];
      priorities.forEach((priority) => {
        const yaml = getValidYaml({ priority });
        const result = validator.validate(yaml);
        expect(result.valid).toBe(true);
      });
    });

    test('所有 status 枚举值应被接受', () => {
      const statuses = ['draft', 'reviewing', 'approved', 'rejected'];
      statuses.forEach((status) => {
        const yaml = getValidYaml({ status });
        const result = validator.validate(yaml);
        expect(result.valid).toBe(true);
      });
    });

    test('空数组的可选字段应被接受', () => {
      const yaml = getValidYaml({
        dependencies: [],
        acceptance_criteria: [],
        tags: []
      });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(true);
    });
  });

  describe('必填字段缺失', () => {
    test('缺少 intent_id 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/intent_id: "R001"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });

    test('缺少 description 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/description: "用户登录流程优化"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });

    test('缺少 layer 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/layer: "input"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });

    test('缺少 priority 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/priority: "P0"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });

    test('缺少 ownership 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/ownership:\n  design: "Alice"\n  product: "Bob"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });

    test('缺少 status 应失败', () => {
      const yaml = getValidYaml();
      const modified = yaml.replace(/status: "draft"\n/, '');
      const result = validator.validate(modified);
      expect(result.valid).toBe(false);
    });
  });

  describe('无效枚举值', () => {
    test('无效 layer 值应失败', () => {
      const yaml = getValidYaml({ layer: 'invalid_layer' });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(false);
    });

    test('无效 priority 值应失败', () => {
      const yaml = getValidYaml({ priority: 'P3' });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(false);
    });

    test('无效 status 值应失败', () => {
      const yaml = getValidYaml({ status: 'pending' });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(false);
    });
  });

  describe('边界情况', () => {
    test('空字符串应失败', () => {
      const result = validator.validate('');
      expect(result.valid).toBe(false);
    });

    test('纯空格字符串应失败', () => {
      const result = validator.validate('   ');
      expect(result.valid).toBe(false);
    });

    test('非对象 YAML（纯字符串）应失败', () => {
      const result = validator.validate('just a string');
      expect(result.valid).toBe(false);
    });

    test('无效的 YAML 语法应返回格式错误', () => {
      const invalidYaml = `
        intent_id: "R001"
        description: "test"
        layer: [unclosed bracket
      `;
      const result = validator.validate(invalidYaml);
      expect(result.valid).toBe(false);
      expect(result.errors?.[0]).toMatch(/YAML parse error/);
    });

    test('无效的 intent_id 格式应失败', () => {
      const yaml = getValidYaml({ intent_id: 'invalid' });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(false);
    });

    test('无效的 version 格式应失败', () => {
      const yaml = getValidYaml({ version: 'v1.0' });
      const result = validator.validate(yaml);
      expect(result.valid).toBe(false);
    });
  });

  describe('静态便捷方法', () => {
    test('quickValidate 应返回校验结果', () => {
      const yaml = getValidYaml();
      const result = FormatValidator.quickValidate(yaml);
      expect(result.valid).toBe(true);
    });
  });
});
